{
  "name": "use-batch-mount",
  "version": "1.0.0",
  "description": "A React custom Hook that mounts a large number of components in batches, preventing memory spikes and browser freezes.",
  "type": "module",
  "main": "dist/useBatchMount.umd.cjs",
  "module": "dist/useBatchMount.js",
  "exports": {
    ".": {
      "import": "./dist/useBatchMount.js",
      "require": "./dist/useBatchMount.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build -c vite.demo.config.js",
    "test": "vitest run"
  },
  "keywords": [
    "react",
    "hook",
    "batch",
    "mount",
    "performance",
    "idle",
    "requestIdleCallback"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.0.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.5",
    "react-redux": "^9.0.4",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "react-redux": "^9.2.0"
  }
}
